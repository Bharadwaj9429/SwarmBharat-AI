{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd backend && python main.py",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "backend": {
      "source": {
        "rootDir": "backend"
      },
      "ports": [
        {
          "port": 8000,
          "protocol": "HTTP"
        }
      ],
      "environment": {
        "NODE_ENV": "production",
        "PYTHONPATH": "/app/backend"
      }
    }
  }
}
